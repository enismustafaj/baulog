#!/usr/bin/env python3
"""entire-agent-baulog — Entire.io external agent plugin for the Baulog ContentAgent.

Discovered automatically by the Entire CLI when placed on $PATH.
Communicates via JSON subcommands over stdin/stdout (protocol version 1).
"""

from __future__ import annotations

import argparse
import base64
import json
import os
import sys
from datetime import datetime, timezone
from pathlib import Path

# ──────────────────────────────────────────────────────────
# Constants
# ──────────────────────────────────────────────────────────

AGENT_NAME = "baulog"
PROTOCOL_VERSION = 1
SESSION_SUBDIR = ".baulog/entire-sessions"
HOOKS_CONFIG_PATH = ".baulog/hooks/entire.json"
TRANSCRIPT_EXT = ".jsonl"
HOOK_NAMES = ["session-start", "stop", "session-end"]


# ──────────────────────────────────────────────────────────
# Required subcommands
# ──────────────────────────────────────────────────────────

def cmd_info(_args: argparse.Namespace) -> None:
    _out({
        "protocol_version": PROTOCOL_VERSION,
        "name": AGENT_NAME,
        "type": "Baulog",
        "description": "Baulog ContentAgent — AI-powered property-management document editor",
        "is_preview": False,
        "protected_dirs": [".baulog"],
        "hook_names": HOOK_NAMES,
        "capabilities": {
            "hooks": True,
            "transcript_analyzer": True,
            "transcript_preparer": False,
            "token_calculator": False,
            "text_generator": False,
            "hook_response_writer": False,
            "subagent_aware_extractor": False,
        },
    })


def cmd_detect(_args: argparse.Namespace) -> None:
    try:
        import langchain_google_genai  # noqa: F401
        present = True
    except ImportError:
        present = False
    _out({"present": present})


def cmd_get_session_id(_args: argparse.Namespace) -> None:
    hook_input = _read_stdin_json()
    _out({"session_id": hook_input["session_id"]})


def cmd_get_session_dir(args: argparse.Namespace) -> None:
    session_dir = str(Path(args.repo_path) / SESSION_SUBDIR)
    _out({"session_dir": session_dir})


def cmd_resolve_session_file(args: argparse.Namespace) -> None:
    session_file = str(Path(args.session_dir) / f"{args.session_id}{TRANSCRIPT_EXT}")
    _out({"session_file": session_file})


def cmd_read_session(_args: argparse.Namespace) -> None:
    hook_input = _read_stdin_json()
    session_id = hook_input.get("session_id", "")
    session_ref = hook_input.get("session_ref", "")
    repo_root = os.environ.get("ENTIRE_REPO_ROOT", "")

    native_data: str | None = None
    if session_ref:
        p = Path(session_ref)
        if p.exists():
            native_data = base64.b64encode(p.read_bytes()).decode()

    _out({
        "session_id": session_id,
        "agent_name": AGENT_NAME,
        "repo_path": repo_root,
        "session_ref": session_ref,
        "start_time": _now(),
        "native_data": native_data,
        "modified_files": [],
        "new_files": [],
        "deleted_files": [],
    })


def cmd_write_session(_args: argparse.Namespace) -> None:
    session = _read_stdin_json()
    session_ref = session.get("session_ref", "")
    native_data = session.get("native_data")
    if session_ref and native_data:
        path = Path(session_ref)
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_bytes(base64.b64decode(native_data))
    # Exit 0 on success (implicit)


def cmd_read_transcript(args: argparse.Namespace) -> None:
    path = Path(args.session_ref)
    if path.exists():
        sys.stdout.buffer.write(path.read_bytes())


def cmd_chunk_transcript(args: argparse.Namespace) -> None:
    raw = sys.stdin.buffer.read()
    max_size = args.max_size
    chunks = [
        base64.b64encode(raw[i : i + max_size]).decode()
        for i in range(0, len(raw), max_size)
    ]
    _out({"chunks": chunks})


def cmd_reassemble_transcript(_args: argparse.Namespace) -> None:
    data = _read_stdin_json()
    for chunk_b64 in data.get("chunks", []):
        sys.stdout.buffer.write(base64.b64decode(chunk_b64))


def cmd_format_resume_command(args: argparse.Namespace) -> None:
    _out({"command": f"baulog --resume {args.session_id}"})


# ──────────────────────────────────────────────────────────
# hooks capability
# ──────────────────────────────────────────────────────────

_HOOK_EVENT_TYPES: dict[str, int] = {
    "session-start": 1,
    "session_start": 1,
    "user_prompt_submit": 2,
    "stop": 3,
    "session-end": 5,
    "session_end": 5,
}


def cmd_parse_hook(args: argparse.Namespace) -> None:
    hook_name = args.hook
    event_type = _HOOK_EVENT_TYPES.get(hook_name)
    if event_type is None:
        print("null")
        return

    hook_input = _read_stdin_json()
    event: dict = {
        "type": event_type,
        "session_id": hook_input.get("session_id", ""),
    }
    if hook_input.get("session_ref"):
        event["session_ref"] = hook_input["session_ref"]
    if hook_input.get("user_prompt"):
        event["prompt"] = hook_input["user_prompt"]
    if hook_input.get("timestamp"):
        event["timestamp"] = hook_input["timestamp"]
    else:
        event["timestamp"] = _now()
    _out(event)


def cmd_install_hooks(_args: argparse.Namespace) -> None:
    repo_root = Path(os.environ.get("ENTIRE_REPO_ROOT", "."))
    config_path = repo_root / HOOKS_CONFIG_PATH
    config_path.parent.mkdir(parents=True, exist_ok=True)
    config_path.write_text(
        json.dumps(
            {
                "hooks": {
                    "session-start": {
                        "description": "Fired when a baulog content-adjustment operation starts"
                    },
                    "stop": {
                        "description": "Fired when a baulog content-adjustment turn completes"
                    },
                    "session-end": {
                        "description": "Fired when a baulog session terminates"
                    },
                }
            },
            indent=2,
        )
    )
    _out({"hooks_installed": len(HOOK_NAMES)})


def cmd_uninstall_hooks(_args: argparse.Namespace) -> None:
    repo_root = Path(os.environ.get("ENTIRE_REPO_ROOT", "."))
    config_path = repo_root / HOOKS_CONFIG_PATH
    if config_path.exists():
        config_path.unlink()
    # Exit 0 on success (implicit)


def cmd_are_hooks_installed(_args: argparse.Namespace) -> None:
    repo_root = Path(os.environ.get("ENTIRE_REPO_ROOT", "."))
    config_path = repo_root / HOOKS_CONFIG_PATH
    _out({"installed": config_path.exists()})


# ──────────────────────────────────────────────────────────
# transcript_analyzer capability
# ──────────────────────────────────────────────────────────

def cmd_get_transcript_position(args: argparse.Namespace) -> None:
    path = Path(args.path)
    pos = path.stat().st_size if path.exists() else 0
    _out({"position": pos})


def cmd_extract_modified_files(args: argparse.Namespace) -> None:
    """Parse the session JSONL from *offset* to find files written by ContentAgent."""
    path = Path(args.path)
    offset = args.offset
    modified: list[str] = []
    current_position = offset

    if path.exists():
        raw = path.read_bytes()
        current_position = len(raw)
        chunk = raw[offset:].decode("utf-8", errors="replace")
        for line in chunk.splitlines():
            line = line.strip()
            if not line:
                continue
            try:
                entry = json.loads(line)
                # ContentAgent.adjust() returns {"markdown_path": "...", "updated": true, ...}
                if entry.get("updated") and entry.get("markdown_path"):
                    rel = entry["markdown_path"]
                    if rel not in modified:
                        modified.append(rel)
            except json.JSONDecodeError:
                pass

    _out({"files": modified, "current_position": current_position})


# ──────────────────────────────────────────────────────────
# Helpers
# ──────────────────────────────────────────────────────────

def _out(data: object) -> None:
    print(json.dumps(data), flush=True)


def _read_stdin_json() -> dict:
    return json.loads(sys.stdin.read())


def _now() -> str:
    return datetime.now(timezone.utc).isoformat()


# ──────────────────────────────────────────────────────────
# CLI entry-point
# ──────────────────────────────────────────────────────────

def main() -> None:
    parser = argparse.ArgumentParser(
        prog="entire-agent-baulog",
        description="Entire.io external agent plugin for Baulog ContentAgent",
    )
    sub = parser.add_subparsers(dest="command")

    # ── required ──────────────────────────────────────────
    sub.add_parser("info")
    sub.add_parser("detect")
    sub.add_parser("get-session-id")

    p = sub.add_parser("get-session-dir")
    p.add_argument("--repo-path", required=True)

    p = sub.add_parser("resolve-session-file")
    p.add_argument("--session-dir", required=True)
    p.add_argument("--session-id", required=True)

    sub.add_parser("read-session")
    sub.add_parser("write-session")

    p = sub.add_parser("read-transcript")
    p.add_argument("--session-ref", required=True)

    p = sub.add_parser("chunk-transcript")
    p.add_argument("--max-size", type=int, required=True)

    sub.add_parser("reassemble-transcript")

    p = sub.add_parser("format-resume-command")
    p.add_argument("--session-id", required=True)

    # ── hooks capability ──────────────────────────────────
    p = sub.add_parser("parse-hook")
    p.add_argument("--hook", required=True)

    p = sub.add_parser("install-hooks")
    p.add_argument("--local-dev", action="store_true")
    p.add_argument("--force", action="store_true")

    sub.add_parser("uninstall-hooks")
    sub.add_parser("are-hooks-installed")

    # ── transcript_analyzer capability ────────────────────
    p = sub.add_parser("get-transcript-position")
    p.add_argument("--path", required=True)

    p = sub.add_parser("extract-modified-files")
    p.add_argument("--path", required=True)
    p.add_argument("--offset", type=int, default=0)

    args = parser.parse_args()

    dispatch = {
        "info": cmd_info,
        "detect": cmd_detect,
        "get-session-id": cmd_get_session_id,
        "get-session-dir": cmd_get_session_dir,
        "resolve-session-file": cmd_resolve_session_file,
        "read-session": cmd_read_session,
        "write-session": cmd_write_session,
        "read-transcript": cmd_read_transcript,
        "chunk-transcript": cmd_chunk_transcript,
        "reassemble-transcript": cmd_reassemble_transcript,
        "format-resume-command": cmd_format_resume_command,
        "parse-hook": cmd_parse_hook,
        "install-hooks": cmd_install_hooks,
        "uninstall-hooks": cmd_uninstall_hooks,
        "are-hooks-installed": cmd_are_hooks_installed,
        "get-transcript-position": cmd_get_transcript_position,
        "extract-modified-files": cmd_extract_modified_files,
    }

    if args.command not in dispatch:
        parser.print_help(sys.stderr)
        sys.exit(1)

    try:
        dispatch[args.command](args)
    except Exception as exc:  # noqa: BLE001
        print(f"entire-agent-baulog: {exc}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
