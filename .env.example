# Google Gemini API Key
# Get your key from: https://ai.google.dev/
GOOGLE_API_KEY=your_google_api_key_here

# Email Webhook Configuration (Optional)
# Secret for validating email webhook signatures
EMAIL_WEBHOOK_SECRET=your_email_webhook_secret_here

# Slack Configuration (Optional)
# Slack App Signing Secret from: https://api.slack.com/apps
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# ERP Webhook Configuration (Optional)
# Secret for validating ERP webhook signatures
ERP_WEBHOOK_SECRET=your_erp_webhook_secret_here

# Server Configuration (Optional)
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Agent Configuration (Optional)
# Gemini model to use: gemini-1.5-flash, gemini-1.5-pro
AGENT_MODEL=gemini-1.5-flash
# Agent temperature: 0.0 (deterministic) to 1.0 (creative)
AGENT_TEMPERATURE=0.3
