# Google Gemini API key — required by all agents
# Get yours at: https://ai.google.dev/
GOOGLE_API_KEY=

# Gemini model used by all agents (default: gemini-2.5-flash-preview-05-20)
GEMINI_MODEL=gemini-2.5-flash-preview-05-20

# Directory where property Markdown files are stored and read from (default: data/properties)
BAULOG_PROPERTIES_DIR=data/properties

# Set to false/0/no to disable the background queue worker on startup (default: true)
BAULOG_RUN_WORKER=true

# Number of queue items processed per worker batch (default: 10)
BAULOG_WORKER_BATCH_SIZE=10

# Seconds between worker queue polls (default: 5)
BAULOG_WORKER_POLL_INTERVAL=5
